# ── Relay API Platform — Environment Variables ──────────────────────────────

# MongoDB connection string (required)
# Local:  mongodb://localhost:27017/relay
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/relay?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/relay

# HTTP server port (default: 3000)
PORT=3000

# 64-character hex key for AES-256-GCM secrets vault encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Back this up. Losing it means encrypted secrets are unrecoverable.
SECRET_ENCRYPTION_KEY=replace_with_64_char_hex_string_generated_by_command_above
